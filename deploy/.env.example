# ─────────────────────────────────────────────────────────────────────────────
# 顽童记 — 服务器环境变量模板
# 复制为 /app/.env 并填入正式值
# 敏感信息：请勿提交此文件至 git
# ─────────────────────────────────────────────────────────────────────────────

# ── 运行环境 ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── 数据库（火山引擎 veDB / 自建 PostgreSQL）──────────────────────────────
# 格式：postgresql://用户名:密码@内网IP:5432/数据库名
DATABASE_URL=postgresql://wantong:your_password@172.x.x.x:5432/wantong

# ── 对象存储（火山引擎 TOS，S3 兼容模式）─────────────────────────────────
STORAGE_PROVIDER=s3

# TOS 端点（https://tos-<region>.volces.com）
S3_ENDPOINT=https://tos-cn-beijing.volces.com
S3_REGION=cn-beijing
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your_tos_access_key_id
S3_SECRET_KEY=your_tos_secret_access_key

# TOS Bucket 内的路径前缀
S3_PRIVATE_PREFIX=private
S3_PUBLIC_PREFIX=public

# ── Clerk 认证（保持与 Replit 相同的密钥）────────────────────────────────
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI 服务 ───────────────────────────────────────────────────────────────
# DeepSeek（国内直连，无需代理）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 火山引擎方舟（替代 OpenAI，国内直连）
# ARK_API_KEY=your_ark_api_key
# ARK_MODEL_ID=your_model_endpoint_id

# 如仍需 OpenAI（需境外代理），保留此项：
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 支付（虎皮椒/微信支付，保持不变）────────────────────────────────────
HUPI_APPID=your_hupi_appid
HUPI_APPSECRET=your_hupi_appsecret

# ── 邮件（可选；国内推荐用 SendCloud 或阿里云 DirectMail）────────────────
# 方案 A：继续用 Resend（境外，连通性可接受）
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 方案 B：SendCloud（国内，取消注释后修改 email.ts）
# SENDCLOUD_API_USER=your_sendcloud_api_user
# SENDCLOUD_API_KEY=your_sendcloud_api_key

# ── 监控（可选）──────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# ── 管理员（与 Replit 保持一致）──────────────────────────────────────────
ADMIN_USER_IDS=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ── 其他 ─────────────────────────────────────────────────────────────────
# API_BASE_URL=https://yourdomain.com
